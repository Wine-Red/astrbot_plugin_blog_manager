{
  "github_token": {
    "description": "GitHub Personal Access Token",
    "type": "string",
    "default": "",
    "hint": "需要至少具备目标博客仓库的内容写入权限。",
    "obvious_hint": true
  },
  "github_owner": {
    "description": "目标博客仓库 owner",
    "type": "string",
    "default": ""
  },
  "github_repo": {
    "description": "目标博客仓库名",
    "type": "string",
    "default": ""
  },
  "default_branch": {
    "description": "目标仓库默认分支",
    "type": "string",
    "default": "main"
  },
  "write_mode": {
    "description": "默认写入模式",
    "type": "string",
    "default": "pr",
    "options": ["pr", "direct"]
  },
  "pr_branch_prefix": {
    "description": "PR 工作分支前缀",
    "type": "string",
    "default": "astrbot/blog"
  },
  "content_dir": {
    "description": "Astro 内容目录",
    "type": "string",
    "default": "src/content/posts"
  },
  "asset_dir": {
    "description": "图片资源目录",
    "type": "string",
    "default": "src/assets/blog"
  },
  "article_format": {
    "description": "文章文件格式",
    "type": "string",
    "default": "md",
    "options": ["md", "mdx"]
  },
  "image_mode": {
    "description": "图片处理模式",
    "type": "string",
    "default": "external",
    "options": ["external", "download"]
  },
  "cover_image_provider": {
    "description": "封面图生成服务",
    "type": "string",
    "default": "",
    "options": ["", "gitee"],
    "hint": "设为 gitee 后，缺少封面图时会调用 Gitee 文生图接口生成本地封面资源。"
  },
  "gitee_image_api_key": {
    "description": "Gitee AI API Key",
    "type": "string",
    "default": "",
    "hint": "用于调用 https://ai.gitee.com/v1/images/generations。"
  },
  "gitee_image_base_url": {
    "description": "Gitee AI OpenAI 兼容接口地址",
    "type": "string",
    "default": "https://ai.gitee.com/v1"
  },
  "gitee_image_model": {
    "description": "Gitee 文生图模型名",
    "type": "string",
    "default": "",
    "hint": "填写你在 Gitee AI 控制台可用的图像生成模型，例如 FLUX/Qwen-Image 类模型的实际 model id。"
  },
  "gitee_image_size": {
    "description": "Gitee 文生图尺寸",
    "type": "string",
    "default": "1024x1024"
  },
  "cover_image_style_prompt": {
    "description": "封面图风格提示词",
    "type": "text",
    "default": "现代中文技术博客封面，信息图风格，清晰主体，干净构图，高对比但不过度炫光，不要文字、水印、logo、二维码。"
  },
  "site_base_url": {
    "description": "站点前缀 URL",
    "type": "string",
    "default": "/",
    "hint": "用于拼接文章链接，例如 https://example.com/blog。"
  },
  "frontmatter_schema_mode": {
    "description": "frontmatter 校验模式",
    "type": "string",
    "default": "astro_common",
    "options": ["astro_common", "custom"]
  },
  "required_frontmatter_fields": {
    "description": "frontmatter 必填字段",
    "type": "list",
    "default": ["title", "published"]
  },
  "default_frontmatter_template": {
    "description": "默认 frontmatter 模板",
    "type": "text",
    "default": "{\n  \"draft\": false,\n  \"comment\": true,\n  \"pinned\": false,\n  \"category\": \"技术\"\n}",
    "hint": "请填写 JSON 或 YAML 对象，例如 {\"draft\": false, \"comment\": true, \"pinned\": false, \"category\": \"技术\"}。",
    "editor_mode": true,
    "editor_language": "json"
  },
  "writing_guide_path": {
    "description": "写作格式指导文件路径",
    "type": "string",
    "default": "",
    "hint": "留空时默认读取插件目录下的 example.md。可填写绝对路径或相对当前工作目录的路径。"
  },
  "writing_guide_max_chars": {
    "description": "写作格式指导最大注入字符数",
    "type": "int",
    "default": 12000
  },
  "allow_auto_publish": {
    "description": "是否允许自然语言直接发布",
    "type": "bool",
    "default": true
  },
  "allow_generated_sources": {
    "description": "是否允许模型正文中自行生成来源链接",
    "type": "bool",
    "default": false,
    "hint": "关闭时，只有用户输入或工具确认的 URL 会被当作可核验来源，可减少瞎编参考链接。"
  },
  "agent_system_prompt": {
    "description": "Agent 系统提示词",
    "type": "text",
    "default": "你是一个严谨的 Astro 博客编辑和技术写作者。你必须生成结构完整、信息密度高、适合直接发布到 Astro 博客仓库的文章。输出内容要准确、自然、具体，避免空泛套话，frontmatter 必须与正文一致，并主动补全合适的分类、标签、摘要和可发布的文章结构。"
  }
}
